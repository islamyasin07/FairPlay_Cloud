# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# CloudWatch Overview Charts
# Namespace and metrics used by the Overview page charts.
# Dimensions use the format Name=Value,AnotherName=AnotherValue
CLOUDWATCH_OVERVIEW_NAMESPACE=FairPlay/Overview
CLOUDWATCH_TREND_METRIC_NAME=ThreatActivityCount
CLOUDWATCH_TREND_STATISTIC=Sum
CLOUDWATCH_TREND_PERIOD_SECONDS=3600
CLOUDWATCH_TREND_LOOKBACK_HOURS=12
CLOUDWATCH_BASE_DIMENSIONS=Environment=prod
CLOUDWATCH_TREND_DIMENSIONS=MetricType=ThreatTrend
CLOUDWATCH_DISTRIBUTION_METRIC_NAME=ThreatActivityCount
CLOUDWATCH_DISTRIBUTION_STATISTIC=Sum
CLOUDWATCH_DISTRIBUTION_DIMENSION_NAME=CheatType
CLOUDWATCH_DISTRIBUTION_CATEGORIES=Aimbot,Speed Hack,No Recoil,Wallhack,Trigger Bot

# DynamoDB Tables
PLAYERS_TABLE=Players
INCIDENTS_TABLE=Incidents
AUDITLOGS_TABLE=AuditLogs
SYSTEMHEALTH_TABLE=SystemHealth
CASE_COMMANDS_TABLE=CASE_COMMANDS_TABLE
ADMINUSERS_TABLE=AdminUsers

# JWT Configuration
JWT_SECRET=your_strong_random_secret_at_least_32_characters_long
JWT_EXPIRES_IN=1d
JWT_ISSUER=fairplay-cloud-backend
JWT_AUDIENCE=fairplay-cloud-frontend

# Bootstrap
BOOTSTRAP_ADMIN_KEY=your_bootstrap_key_here
